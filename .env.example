# ──────────────────────────────────────────────────────────────
# MES – Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# No Railway, configure diretamente no painel de variáveis.
# ──────────────────────────────────────────────────────────────

# Ambiente (development | production)
NODE_ENV=production

# Porta do servidor (Railway define automaticamente via $PORT)
# PORT=3001

# Segredo JWT — use uma string longa e aleatória em produção!
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_por_string_aleatoria_longa

# Caminho do banco SQLite
# Em produção no Railway, aponte para o volume persistente montado (ex.: /data/mes.db)
# Em desenvolvimento, deixe em branco para usar backend/data/mes.db
# DB_PATH=/data/mes.db

# ── E-mail (opcional) ─────────────────────────────────────────
# Usado para enviar senhas temporárias a novos operadores.
# Conta Gmail com "senha de app" habilitada (não a senha normal).
# GMAIL_USER=seuemail@gmail.com
# GMAIL_PASS=xxxx xxxx xxxx xxxx
